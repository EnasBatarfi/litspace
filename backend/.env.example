APP_NAME=LitSpace
APP_ENV=development
DATA_DIR=../data
RAW_PDF_DIR=../data/raw
PROCESSED_DIR=../data/processed
INDEX_DIR=../data/indexes
EVAL_DIR=../data/eval
SQLITE_PATH=../data/litspace.db

EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

LLM_PROVIDER=openai
LLM_FALLBACK_ENABLED=true
# If LLM_PROVIDER_CHAIN is set, it should be a comma-separated list of providers to try in order, e.g. "gemini,openai,anthropic"
LLM_PROVIDER_CHAIN=openai,ollama

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=https://api.openai.com/v1

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2:3b
OLLAMA_MODEL=qwen3:8b
# OLLAMA_MODEL=gemma3:4b

DEFAULT_ANSWER_TOP_K=6
DEFAULT_ANSWER_MAX_TOKENS=500
DEFAULT_ANSWER_TEMPERATURE=0.1
